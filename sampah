session_start();
require_once 'components/database.php';

// PERBAIKAN: Ganti fungsi dengan validasi manual
if (!isset($_SESSION['user_id']) || $_SESSION['role'] != 'user') {
    header('Location: login.php');
    exit();
}

$user_id = $_SESSION['user_id'];

// Get user info - PERBAIKI NAMA TABEL
$user_query = mysqli_query($conn, "SELECT * FROM users WHERE id = $user_id");
$user = mysqli_fetch_assoc($user_query);

// PERBAIKI: Nama tabel dan kolom yang benar
$cart_items = mysqli_query($conn, 
    "SELECT k.*, p.nama, p.harga, p.gambar, p.stok 
     FROM keranjang k 
     JOIN produk p ON k.produk_id = p.id 
     WHERE k.user_id = $user_id");

// Calculate total
$total = 0;
$items = [];
while ($item = mysqli_fetch_assoc($cart_items)) {
    $item_total = $item['harga'] * $item['jumlah'];
    $total += $item_total;
    $items[] = $item;
}

// PERBAIKAN: Pindahkan kode ini setelah deklarasi variabel
// Process checkout
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $shipping_address = mysqli_real_escape_string($conn, $_POST['shipping_address']);
    $payment_method = mysqli_real_escape_string($conn, $_POST['payment_method']);
    $notes = mysqli_real_escape_string($conn, $_POST['notes']);
    
    // PERBAIKAN: Start transaction
    mysqli_begin_transaction($conn);
    
    try {
        // PERBAIKAN: Nama tabel dan kolom
        $order_query = "INSERT INTO orders (user_id, total_amount, shipping_address, payment_method, notes, status) 
                       VALUES ($user_id, $total, '$shipping_address', '$payment_method', '$notes', 'pending')";
        
        if (mysqli_query($conn, $order_query)) {
            $order_id = mysqli_insert_id($conn);
            
            // Add order items
            foreach ($items as $item) {
                $product_id = $item['produk_id'];
                $quantity = $item['jumlah'];
                $price = $item['harga'];
                
                // PERBAIKAN: Nama tabel
                $order_item_query = "INSERT INTO order_items (order_id, product_id, quantity, price) 
                                    VALUES ($order_id, $product_id, $quantity, $price)";
                mysqli_query($conn, $order_item_query);
                
                // PERBAIKAN: Nama tabel dan kolom
                $update_stock_query = "UPDATE produk SET stok = stok - $quantity WHERE id = $product_id";
                mysqli_query($conn, $update_stock_query);
            }
            
            // PERBAIKAN: Nama tabel
            $clear_cart_query = "DELETE FROM keranjang WHERE user_id = $user_id";
            mysqli_query($conn, $clear_cart_query);
            
            // Commit transaction
            mysqli_commit($conn);
            
            $_SESSION['order_success'] = true;
            $_SESSION['order_id'] = $order_id;
            header('Location: order_confirmation.php?id=' . $order_id);
            exit();
        } else {
            throw new Exception("Gagal membuat pesanan: " . mysqli_error($conn));
        }
    } catch (Exception $e) {
        // Rollback transaction on error
        mysqli_rollback($conn);
        $error = "Terjadi kesalahan saat memproses pesanan: " . $e->getMessage();
    }
}

